{
  "name": "OpenRowingMonitor",
  "version": "0.9.8",
  "description": "A free and open source performance monitor for rowing machines",
  "main": "app/server.js",
  "author": "Jaap van Ekris",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaapvanEkris/openrowingmonitor.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "*",
    "!/**/*.test.js"
  ],
  "scripts": {
    "lint": "eslint ./app ./config && markdownlint-cli2 '**/*.md' '#node_modules'",
    "start": "node app/server.js",
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "test": "uvu -i client && npm run test:client",
    "test:client": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm test"
  },
  "dependencies": {
    "@markw65/fit-file-writer": "^0.1.9",
    "@zakj/no-sleep": "^0.13.6",
    "ble-host": "github:Abasz/node-ble-host",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "finalhandler": "^2.1.1",
    "incyclist-ant-plus": "^0.3.6",
    "lit": "^3.2.0",
    "loglevel": "^1.9.1",
    "mqtt": "^5.15.1",
    "node-fetch": "^3.3.2",
    "pigpio": "3.3.1",
    "replace-in-file": "^8.4.0",
    "serve-static": "^2.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.0.0",
    "happy-dom": "^20.8.8",
    "http2-proxy": "5.0.53",
    "markdownlint-cli2": "^0.22.0",
    "nodemon": "^3.1.11",
    "npm-run-all": "4.1.5",
    "simple-git-hooks": "^2.13.1",
    "tar": "^7.5.13",
    "typescript": "^5.9.3",
    "uvu": "^0.5.6",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
